{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "default": "data source=auth.db"
  },
  "AuthServerUrl": "https://localhost:7001",
  "IdentityServerConfig": {
    "ApiScopes": [
      {
        "Name": "app.read",
        "DisplayName": "Application Read Access",
      },
      {
        "Name": "app.write",
        "DisplayName": "Application Write Access"
      },
      {
        "Name": "all.backup",
        "DisplayName": "Application Backup Request Access"
      }
    ],
    "Clients": [
      {
        // Makine/Servis gibi otonom sistemler şifre sormadan çalışır.
        "ClientId": "backend_processor",
        "ClientSecret": "machine_secret_key",
        "GrantType": "ClientCredentials",
        "AllowedScopes": [ "all.backup" ]
      },
      {
        // İnsan faktörlü istemciler (mobil, web apps etc.)
        "ClientId": "sso_app",
        "ClientSecret": "sso_app_secret_key",
        "GrantType": "ResourceOwnerPassword",
        "AllowedScopes": [ "app.read", "app.write", "openid", "profile" ]
      }
    ]
  }
}
